<div class="card">
  <div class="card-body">
    <h3 class="card-title">{{title}}</h3>
    <p class="card-desc">{{description}}</p>
    <div class="card-meta">
      <span>Cupo: {{capacity}}</span>
    </div>
  </div>
  <div class="card-actions">
    <button class="btn" data-action="enroll" data-course-id="{{id}}">Inscribirme</button>
  </div>
</div>