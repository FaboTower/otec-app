<h1>Admin - Calificaciones</h1>
<p class="muted">Registra notas por inscripción (solo APROBADA).</p>

<div class="flash hidden" id="flash"></div>

<div class="card" style="padding:16px; margin-bottom:16px;">
  <h3 style="margin-top:0;">Seleccionar inscripción aprobada</h3>
  <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
    <select id="approvedEnrollmentsSelect" class="select" style="min-width:360px;">
      <option value="">Cargando inscripciones aprobadas...</option>
    </select>
    <button id="btnReloadApproved" class="btn secondary">Recargar</button>
  </div>
  <p id="approvedHint" class="muted" style="margin:10px 0 0 0;"></p>
</div>

<form id="gradeForm" class="card" style="padding:16px;">
  <label>Enrollment ID</label>
  <input id="enrollmentId" type="number" min="1" required style="width:100%;padding:10px;margin:8px 0;">

  <label>Score (0-100)</label>
  <input id="score" type="number" min="0" max="100" required style="width:100%;padding:10px;margin:8px 0;">

  <label>Feedback</label>
  <textarea id="feedback" rows="3" style="width:100%;padding:10px;margin:8px 0;"></textarea>

  <button class="btn" type="submit">Guardar nota</button>
</form>

<script src="/js/admin-grades.js"></script>